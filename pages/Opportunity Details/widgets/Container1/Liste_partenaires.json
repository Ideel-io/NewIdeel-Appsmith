    "customColumn1": {
      "alias": "Com estimée / an",
      "allowCellWrapping": false,
      "buttonStyle": "rgb(3, 179, 101)",
      "cellBackground": "{{Liste_partenaires.processedTableData.map((currentRow, currentIndex) => ( (currentRow[\"price\"] / 100) * 12 - (getProcedureById.data.data.getProcedureById.recurrentSubscription.price * utils.ratio[getProcedureById.data.data.getProcedureById.recurrentSubscription.periodicity] / (100)) * 12  < 0 && (currentRow[\"price\"] / 100) > 0 ? 'lightgreen' : function(){\n\tconst c = currentRow[\"name\"];\n\tswitch(true){\n\t\tcase c.includes(\"Flitter ne trouve pas de modèle avec la date d'achat donné\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes(\"La date d'acquisition du bonus 50 est incompatible\"):\n\t\t\treturn \"yellow\"\n\t\t\tbreak;\n\t\tcase c.includes(\"ce taux de responsabilité ne peut être\"):\n\t\t\treturn \"yellow\"\n\t\t\tbreak;\n\t\tcase c.includes(\"_get_month_birth() => list index out of range\"):\n\t\t\treturn \"yellow\"\n\t\t\tbreak;\n\t\tcase c.includes(\"_set_birthdate() => list index out of range\"):\n\t\t\treturn \"yellow\"\n\t\t\tbreak;\n\t\tcase c.includes(\"(ou date d'achat si\"):\n\t\t\treturn \"yellow\"\n\t\t\tbreak;\n\t\tcase c.includes(\"Le nombre de sinistres est supérieur ou égal à 3\"):\n\t\t\treturn \"yellow\"\n\t\t\tbreak;\n\t\tcase c.includes(\"les antécédents sinistre ne respectent pas les règles d'acceptation : souscription interdite.\"):\n\t\t\treturn \"les antécédents sinistre ne respectent pas les règles d'acceptation : souscription interdite.\"\n\t\t\tbreak;\n\t\tcase c.includes(\"Plus d'un sinistre responsable\"):\n\t\t\treturn \"yellow\"\n\t\t\tbreak;\n\t\tcase c.includes(\"AXA n'arrive pas à donner de tarif et conseille de contacter votre interlocuteur habituel.\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes(\"Suspension de permis : non encore autorisé\"):\n\t\t\treturn \"yellow\"\n\t\t\tbreak;\n\t\tcase c.includes(\"Ce modèle de voiture est pas géré\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes(\"Le coefficient RM est supérieur à 1,95\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes(\"No vehicle found for License plate\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes(\"Flitter ne trouve pas le modèle\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes(\"L'âge pour le permis ne peut pas être inférieur à 18 ans\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes(\"ancienneté de permis inférieure à 3 ans\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes('\"valeur du crm à la dernière échéance\" doit être inférieure ou égal à 1'):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes(\"vérifiez la plaque d'immatriculation\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes(\"Annulation de permis :\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes(\"bonus malus est supérieur à 1\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase \n\t\t\tc.includes(\"Pas éligible\"):\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t\tcase c.includes(\"Error\"):\n\t\t\treturn \"red\"\n\t\t\tbreak;\n\t\tdefault:\n\t\t\treturn \"yellow\";\n\t\t\tbreak;\n\t}\n\n}()))}}",
      "columnType": "text",
      "computedValue": "{{(() => { const tableData = Liste_partenaires.processedTableData || []; return tableData.length > 0 ? tableData.map((currentRow, currentIndex) => ( \ncurrentRow[\"Commission\"].includes('€')\n? (parseFloat(currentRow[\"Commission\"].replace('€', '').trim())).toFixed(0)+' €'\n: '['+((parseFloat(Prix.Prix.data) ) / 100 * parseInt(currentRow[\"Commission\"]) * 12 * 0.75).toFixed(0)+' € - '+((parseFloat(Prix.Prix.data) ) / 100 * parseInt(currentRow[\"Commission\"]) * 12 * 1.10).toFixed(0)+' €]'\n)) :  \ncurrentRow[\"Commission\"].includes('€')\n? (parseFloat(currentRow[\"Commission\"].replace('€', '').trim())).toFixed(0)+' €'\n: '['+((parseFloat(Prix.Prix.data) ) / 100 * parseInt(currentRow[\"Commission\"]) * 12 * 0.75).toFixed(0)+' € - '+((parseFloat(Prix.Prix.data) ) / 100 * parseInt(currentRow[\"Commission\"]) * 12 * 1.10).toFixed(0)+' €]'\n })()}}",
